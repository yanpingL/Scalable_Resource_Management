POSTGRES_DB=webdb
POSTGRES_USER=webuser
POSTGRES_PASSWORD=replace-with-a-long-random-password

S3_BUCKET=webserver-files
S3_ACCESS_KEY=replace-with-a-long-random-access-key
S3_SECRET_KEY=replace-with-a-long-random-secret-key
S3_PUBLIC_ENDPOINT=https://api.example.com
S3_UPLOAD_URL_EXPIRES=300
S3_DOWNLOAD_URL_EXPIRES=300
S3_MAX_FILENAME_LENGTH=255
MINIO_API_CORS_ALLOW_ORIGIN=https://your-vercel-app.vercel.app

JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_ISSUER=webserver
JWT_EXPIRES_SECONDS=3600
